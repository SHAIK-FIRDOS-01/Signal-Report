# pyenv
#   For a library or package, you might want to ignore these files since the Python version is usually managed by the user.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in cases where the author of a library or package has a double-entry control system,
#   they may find it more appropriate to ignore Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally included in version control, but may be ignored in certain cases.
# poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock is generally included in version control, but may be ignored in certain cases.
# pdm.lock

# PEP 582; used by e.g. github.com/pypa/pdm
__pypackages__/

